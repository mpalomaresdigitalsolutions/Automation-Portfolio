# Environment Configuration Template
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control!

# DeepSeek API Key
# Get your API key from: https://platform.deepseek.com/api-keys
DS_KEY=your_deepseek_api_key_here

# Google Apps Script Endpoint
# Create your Google Apps Script and deploy as web app
SHEET_URL=your_google_apps_script_url_here

# Instructions:
# 1. Copy this file to .env: `cp .env.example .env`
# 2. Edit .env with your actual values
# 3. Ensure .env is in .gitignore
# 4. Never share your .env file or commit it to Git